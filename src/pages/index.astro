---
/**
 * index.astro — Homepage / gallery page.
 *
 * Shows every analyzed movie in a responsive grid. Each card features
 * the color strip (the visual fingerprint) with the title, year, and
 * palette dots below. Movies are sorted newest-first.
 *
 * The hero section sets the tone: this site is about seeing films
 * through their colors, not their plots.
 */
import Layout from "../layouts/Layout.astro";
import MovieCard from "../components/MovieCard.astro";
import movies from "../data/movies.json";

const totalMovies = movies.length;
---

<Layout>
  <!-- Hero section -->
  <section class="mb-16 md:mb-24" data-movie-search>
    <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl tracking-tight text-text mb-4">
      cinechroma
    </h1>
    <p class="text-text-secondary text-base md:text-lg max-w-xl leading-relaxed">
      Every film has a color story. We extract it frame by frame — dominant
      hues, luminance bands, full palettes — and lay it bare as a visual
      fingerprint.
    </p>
    <p class="text-text-tertiary text-sm mt-3">
      {totalMovies} films analyzed
    </p>

    <!-- Search stays on the homepage so filtering feels instant and local. -->
    <form class="mt-8 max-w-2xl" role="search" aria-label="Search the movie collection">
      <label for="movie-search-input" class="sr-only">Search films by title or year</label>
      <div class="search-shell">
        <svg
          class="search-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.6-5.15a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0z" />
        </svg>

        <input
          id="movie-search-input"
          type="search"
          name="q"
          class="search-input"
          placeholder="Search by title or year"
          autocomplete="off"
          spellcheck="false"
          data-search-input
        />

        <button
          type="button"
          class="search-clear"
          data-search-clear
          hidden
        >
          Clear
        </button>
      </div>

      <p class="mt-3 text-sm text-text-tertiary" data-search-summary>
        {totalMovies} films shown
      </p>
    </form>
  </section>

  <!-- Movie grid -->
  <section>
    <div class="flex items-center justify-between gap-4 mb-8">
      <h2 class="text-xs uppercase tracking-widest text-text-tertiary">
        Collection
      </h2>
    </div>

    <div
      class="search-empty-state"
      data-search-empty
      hidden
    >
      <p class="font-medium text-text">No films match that search.</p>
      <p class="text-sm text-text-secondary mt-2">
        Try a different title or year for
        <span data-search-empty-query></span>.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6" data-search-grid>
      {movies.map((movie) => (
        <div
          data-search-item
          data-search-text={`${movie.title} ${movie.year} ${movie.slug}`.toLowerCase()}
        >
          <MovieCard movie={movie} />
        </div>
      ))}
    </div>
  </section>
</Layout>

<script is:inline>
  const searchRoot = document.querySelector('[data-movie-search]');

  if (searchRoot) {
    const searchInput = searchRoot.querySelector('[data-search-input]');
    const clearButton = searchRoot.querySelector('[data-search-clear]');
    const summary = searchRoot.querySelector('[data-search-summary]');
    const items = Array.from(document.querySelectorAll('[data-search-item]'));
    const emptyState = document.querySelector('[data-search-empty]');
    const emptyQuery = document.querySelector('[data-search-empty-query]');
    const totalItems = items.length;

    const normalizeQuery = (value) => value.trim().toLowerCase().replace(/\s+/g, ' ');

    const syncUrl = (value) => {
      const url = new URL(window.location.href);

      if (value) {
        url.searchParams.set('q', value);
      } else {
        url.searchParams.delete('q');
      }

      history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
    };

    const updateResults = (rawValue) => {
      const trimmedValue = rawValue.trim();
      const query = normalizeQuery(rawValue);
      let visibleItems = 0;

      for (const item of items) {
        const haystack = item.dataset.searchText || '';
        const matches = !query || haystack.includes(query);

        item.hidden = !matches;

        if (matches) {
          visibleItems += 1;
        }
      }

      summary.textContent = query
        ? `${visibleItems} of ${totalItems} films match "${trimmedValue}"`
        : `${totalItems} films shown`;

      clearButton.hidden = trimmedValue.length === 0;
      emptyState.hidden = visibleItems !== 0;
      emptyQuery.textContent = trimmedValue ? `“${trimmedValue}”` : 'that query';

      syncUrl(trimmedValue);
    };

    searchRoot.querySelector('form')?.addEventListener('submit', (event) => {
      event.preventDefault();
    });

    searchInput.addEventListener('input', (event) => {
      updateResults(event.currentTarget.value);
    });

    clearButton.addEventListener('click', () => {
      searchInput.value = '';
      updateResults('');
      searchInput.focus();
    });

    const initialQuery = new URLSearchParams(window.location.search).get('q') || '';

    if (initialQuery) {
      searchInput.value = initialQuery;
    }

    updateResults(initialQuery);
  }
</script>
