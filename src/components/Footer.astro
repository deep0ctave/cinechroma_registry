---
/**
 * Footer.astro — Minimal footer.
 * Links to the cinechroma tool, portfolio, and GitHub.
 */
---

<footer class="py-8 border-t border-border">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 text-xs text-text-tertiary">
    <p>
      built with <a href="https://github.com/deep0ctave/cinechroma_v2" target="_blank" rel="noopener noreferrer" class="link-underline hover:text-text transition-colors">cinechroma</a>
    </p>
    <div class="flex gap-5">
      <a
        href="https://avinashaldhapati.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-text transition-colors"
      >
        portfolio
      </a>
      <a
        href="https://github.com/deep0ctave"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-text transition-colors"
      >
        github
      </a>
    </div>
  </div>
</footer>
