---
/**
 * MovieCard.astro — A single movie entry in the homepage grid.
 *
 * Shows the color strip image as the hero visual, with the movie
 * title, year, and overall palette dots below. The strip is the
 * star — it's what makes each movie visually unique at a glance.
 */
const { movie } = Astro.props;
const overallPalette = movie.palettes?.overall || [];
---

<a
  href={`/movie/${movie.slug}`}
  class="movie-card group block rounded-lg overflow-hidden border border-border bg-bg-card"
>
  <!-- Color strip — the visual fingerprint of the film -->
  <div class="w-full h-16 sm:h-20 overflow-hidden">
    <img
      src={`/movies/${movie.slug}/strip.png`}
      alt={`Color strip for ${movie.title}`}
      class="strip-image"
      loading="lazy"
    />
  </div>

  <!-- Info bar -->
  <div class="px-4 py-3 flex items-center justify-between gap-3">
    <div class="min-w-0">
      <h3 class="text-sm font-medium text-text truncate group-hover:opacity-70 transition-opacity">
        {movie.title}
      </h3>
      <span class="text-xs text-text-tertiary">{movie.year}</span>
    </div>

    <!-- Overall palette dots — 5 small circles showing the movie's color DNA -->
    {overallPalette.length > 0 && (
      <div class="flex gap-1 shrink-0">
        {overallPalette.map((hex) => (
          <div
            class="w-3 h-3 rounded-full border border-white/10"
            style={`background-color: ${hex};`}
            title={hex}
          />
        ))}
      </div>
    )}
  </div>
</a>
