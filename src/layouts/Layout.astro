---
/**
 * Layout.astro — Root layout wrapper for every page.
 *
 * Provides <head> (meta, fonts, dark-mode script), and the
 * shared Header / Footer chrome. Dark mode is ON by default
 * since film colors look best on dark backgrounds.
 */
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "cinechroma — decoding cinema's color DNA",
  description = "Explore the hidden color palettes of iconic films. Every frame analyzed, every hue extracted.",
  ogUrl = "https://cinechroma.avinashaldhapati.com/",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts — Inter (body) + Playfair Display (headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Dark mode: default to dark, respect stored preference -->
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      }
      // Dark is already the default class on <html>
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Avinash Aldhapati" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
  </head>

  <body class="min-h-screen flex flex-col">
    <div class="mx-auto w-full max-w-5xl px-6 md:px-8 flex flex-col min-h-screen">
      <Header />

      <main class="flex-grow py-12 md:py-20">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
